{
    "tasks": [
        {
            "label": "Build DRC1200",
            "type": "shell",
            "command": "/bin/sh",
            "args": [
                "-lc",
                "mkdir -p \"${workspaceFolder}/bin/Debug\" && g++ -g -std=gnu++17 *.cpp -o \"${workspaceFolder}/bin/Debug/DRC1200\" $(wx-config --cxxflags --libs)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the full DRC1200 project with wxWidgets"
        }
    ],
    "version": "2.0.0"
}